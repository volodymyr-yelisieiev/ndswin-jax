{
  "name": "cifar10_tuned",
  "description": "High-budget CIFAR-10 classification recipe for tuned 2D NDSwin validation runs",
  "model": {
    "num_dims": 2,
    "patch_size": [2, 2],
    "embed_dim": 96,
    "depths": [2, 2, 18, 2],
    "num_heads": [3, 6, 12, 24],
    "window_size": [4, 4],
    "in_channels": 3,
    "num_classes": 10,
    "drop_rate": 0.0,
    "drop_path_rate": 0.2
  },
  "training": {
    "epochs": 600,
    "batch_size": 128,
    "learning_rate": 0.0008,
    "weight_decay": 0.02,
    "optimizer": "adamw",
    "lr_schedule": "cosine",
    "warmup_epochs": 20,
    "label_smoothing": 0.1,
    "early_stopping": true,
    "patience": 40,
    "min_delta": 0.00005
  },
  "data": {
    "dataset": "cifar10",
    "data_dir": "data/cifar10",
    "image_size": [32, 32],
    "in_channels": 3,
    "task": "classification",
    "mean": [0.4914, 0.4822, 0.4465],
    "std": [0.2023, 0.1994, 0.2010],
    "augmentation": true,
    "random_crop": true,
    "random_flip": true,
    "mixup_alpha": 0.2,
    "cutmix_alpha": 0.5,
    "cutout_size": 8,
    "random_rotation": 0.0,
    "color_jitter": true,
    "auto_augment": false
  }
}
