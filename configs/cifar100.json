{
  "name": "cifar100",
  "description": "CIFAR-100 classification (100 classes, 32x32 images)",
  "model": {
    "num_dims": 2,
    "patch_size": [4, 4],
    "embed_dim": 48,
    "depths": [2, 2, 6, 2],
    "num_heads": [3, 6, 12, 24],
    "window_size": [4, 4],
    "in_channels": 3,
    "num_classes": 100,
    "drop_rate": 0.1,
    "drop_path_rate": 0.3
  },
  "training": {
    "epochs": 100,
    "batch_size": 128,
    "learning_rate": 5e-4,
    "loss": "cross_entropy",
    "weight_decay": 0.05,
    "label_smoothing": 0.1,
    "stochastic_depth_rate": 0.1,
    "warmup_epochs": 10,
    "gradient_clip_norm": 1.0,
    "early_stopping": true,
    "patience": 15,
    "min_delta": 0.001
  },
  "data": {
    "dataset": "cifar100",
    "data_dir": "data/cifar100",
    "image_size": [32, 32],
    "in_channels": 3,
    "task": "classification",
    "download": true,
    "mixup_alpha": 0.8,
    "cutmix_alpha": 1.0,
    "random_crop": true,
    "random_flip": true,
    "random_rotation": 15.0,
    "color_jitter": true
  }
}
