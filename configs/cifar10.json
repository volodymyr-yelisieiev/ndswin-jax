{
  "name": "cifar10",
  "description": "CIFAR-10 classification (10 classes, 32x32 images)",
  "model": {
    "num_dims": 2,
    "patch_size": [2, 2],
    "embed_dim": 48,
    "depths": [2, 2, 6, 2],
    "num_heads": [3, 6, 12, 24],
    "window_size": [4, 4],
    "in_channels": 3,
    "num_classes": 10,
    "drop_rate": 0.1,
    "drop_path_rate": 0.3
  },
  "training": {
    "epochs": 300,
    "batch_size": 512,
    "learning_rate": 0.001,
    "weight_decay": 0.05,
    "optimizer": "adamw",
    "lr_schedule": "cosine",
    "warmup_epochs": 10,
    "label_smoothing": 0.1,
    "early_stopping": true,
    "patience": 15,
    "min_delta": 0.0001
  },
  "data": {
    "dataset": "cifar10",
    "data_dir": "data/cifar10",
    "image_size": [32, 32],
    "in_channels": 3,
    "task": "classification",
    "mean": [0.4914, 0.4822, 0.4465],
    "std": [0.2023, 0.1994, 0.2010],
    "augmentation": true,
    "random_crop": true,
    "random_flip": true,
    "mixup_alpha": 0.2,
    "cutmix_alpha": 1.0,
    "random_rotation": 0.0,
    "color_jitter": false,
    "auto_augment": false
  }
}
